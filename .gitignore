# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/

# ── Virtual environment ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── ML Models (хранятся на HuggingFace, НЕ в GitHub) ────────────────────────
*.h5
*.pkl
*.pt
*.pth
*.bin
*.onnx
*.tflite
models/*.h5
models/*.pkl

# ── Dataset (слишком большой для GitHub) ────────────────────────────────────
dataset/

# ── Uploads (временные файлы пользователей) ──────────────────────────────────
web_app/uploads/*
!web_app/uploads/.gitkeep

# ── Environment variables ────────────────────────────────────────────────────
.env
.env.*
*.env

# ── OS файлы ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Логи ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Кэш HuggingFace ──────────────────────────────────────────────────────────
.cache/
